<?xml version="1.0" encoding="UTF-8"?>
<System>
  <!-- Inport blocks -->
  <Block Name="setpoint" SID="1" BlockType="Inport">
    <P Name="Port">1</P>
  </Block>
  <Block Name="feedback" SID="2" BlockType="Inport">
    <P Name="Port">1</P>
  </Block>

  <!-- Sum: Add1 = setpoint - feedback -->
  <Block Name="Add1" SID="3" BlockType="Sum">
    <P Name="Inputs">+-</P>
  </Block>

  <!-- Gain: P_gain = Add1 * 3 -->
  <Block Name="P_gain" SID="4" BlockType="Gain">
    <P Name="Gain">3</P>
  </Block>

  <!-- Gain: I_gain = Add1 * 2 -->
  <Block Name="I_gain" SID="5" BlockType="Gain">
    <P Name="Gain">2</P>
  </Block>

  <!-- Gain: Ts = I_gain * 0.01 -->
  <Block Name="Ts" SID="6" BlockType="Gain">
    <P Name="Gain">0.01</P>
  </Block>

  <!-- UnitDelay: UnitDelay1 stores Add2 -->
  <Block Name="UnitDelay1" SID="7" BlockType="UnitDelay">
    <P Name="SampleTime">0.01</P>
  </Block>

  <!-- Sum: Add2 = Ts + UnitDelay1 -->
  <Block Name="Add2" SID="8" BlockType="Sum">
    <P Name="Inputs">++</P>
  </Block>

  <!-- Sum: Add3 = P_gain + Add2 -->
  <Block Name="Add3" SID="9" BlockType="Sum">
    <P Name="Inputs">++</P>
  </Block>

  <!-- Outport: command = Add3 -->
  <Block Name="command" SID="10" BlockType="Outport">
    <P Name="Port">1</P>
  </Block>

  <!-- Connections -->
  <Line Name="setpointLine">
    <Src>1#R:1</Src>
    <P Name="Dst">3#L:1</P>
  </Line>
  <Line Name="feedbackLine">
    <Src>2#R:1</Src>
    <P Name="Dst">3#L:2</P>
  </Line>
  <Line Name="add1Line">
    <Src>3#R:1</Src>
    <P Name="Dst">4#L:1</P>
    <Branch>
      <P Name="Dst">5#L:1</P>
    </Branch>
  </Line>
  <Line Name="pGainLine">
    <Src>4#R:1</Src>
    <P Name="Dst">9#L:1</P>
  </Line>
  <Line Name="iGainLine">
    <Src>5#R:1</Src>
    <P Name="Dst">6#L:1</P>
  </Line>
  <Line Name="tsLine">
    <Src>6#R:1</Src>
    <P Name="Dst">8#L:1</P>
  </Line>
  <Line Name="unitDelayLine">
    <Src>7#R:1</Src>
    <P Name="Dst">8#L:2</P>
  </Line>
  <Line Name="add2Line">
    <Src>8#R:1</Src>
    <P Name="Dst">7#L:1</P>
    <Branch>
      <P Name="Dst">9#L:2</P>
    </Branch>
  </Line>
  <Line Name="add3Line">
    <Src>9#R:1</Src>
    <P Name="Dst">10#L:1</P>
  </Line>
</System>
